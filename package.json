  },
  "dependencies": {
    "axios": "^1.7.9",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitest/coverage-v8": "^1.0.4",
    "@vue/test-utils": "^2.4.4",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.21.1",
    "jsdom": "^23.0.1",
    "typescript": "^5.4.2",
    "vite": "^6.0.5",
    "vitest": "^1.0.4",
    "vue-tsc": "^2.0.6"
  }
}
